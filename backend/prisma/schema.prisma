// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}



// ─── Admin ─────────────────────────────────────────────
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // bcrypt hash
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── User (Customer) ───────────────────────────────────
model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String   // bcrypt hash
  phone      String?
  age        Int?
  gender     Gender?
  weight     Float?
  height     Float?
  goal       String?
  experience String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships MembershipPurchase[]
  orders      Order[]
}

// ─── Membership Plan (static catalog) ──────────────────
model MembershipPlan {
  id        Int          @id @default(autoincrement())
  name      String
  duration  String       // e.g. "12 Months"
  price     Float
  currency  String       @default("CHF")
  features  String[]     // stored as array
  category  String       @default("MEMBERSHIP")
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  purchases MembershipPurchase[]
}

// ─── Membership Purchase ────────────────────────────────
model MembershipPurchase {
  id                 Int            @id @default(autoincrement())
  user               User           @relation(fields: [userId], references: [id])
  userId             Int
  plan               MembershipPlan @relation(fields: [planId], references: [id])
  planId             Int
  additionalPlanIds  Int[]          @default([])
  status             ApprovalStatus @default(PENDING)
  registrationFee    Float          @default(0)
  totalAmount        Float?
  startDate          DateTime?
  emergencyContact   String?
  address            String?        @db.Text
  acceptedAgreement  Boolean        @default(false)
  acceptedTerms      Boolean        @default(false)
  signatureDataUrl   String?        @db.Text
  registrationDetails Json?
  notes              String?        // admin can add notes
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

// ─── CMS: Plan Categories ────────────────────────────────
model PlanCategoryItem {
  id        Int      @id @default(autoincrement())
  name      String   @unique     // stored value in MembershipPlan.category
  label     String               // display label
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CMS: Site Content (key-value text/headings) ───────
model SiteContent {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  section   String   // e.g. "hero", "about", "events"
  updatedAt DateTime @updatedAt
}

// ─── CMS: Stats ─────────────────────────────────────────
model Stat {
  id        Int      @id @default(autoincrement())
  value     String
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── CMS: Trainers ─────────────────────────────────────
model Trainer {
  id          Int      @id @default(autoincrement())
  name        String
  role        String
  description String?  @db.Text
  image       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CMS: Testimonials ─────────────────────────────────
model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  rating    Float    @default(5.0)
  content   String   @db.Text
  image     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CMS: Blog Posts ───────────────────────────────────
model BlogPost {
  id        Int      @id @default(autoincrement())
  title     String
  excerpt   String   @db.Text
  content   String?  @db.Text
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CMS: Gallery Images ───────────────────────────────
model GalleryImage {
  id        Int      @id @default(autoincrement())
  src       String
  alt       String
  category  String   @default("All")
  gridCol   String?
  gridRow   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CMS: Achievements ─────────────────────────────────
model Achievement {
  id        Int      @id @default(autoincrement())
  image     String?
  title     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── CMS: Why Choose Us Features ───────────────────────
model WhyChooseUsFeature {
  id          Int      @id @default(autoincrement())
  icon        String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ─── CMS: Event Highlights ─────────────────────────────
model EventHighlight {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  videoUrl    String?
  image       String?
  isMain      Boolean  @default(false)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CMS: Training Zones ───────────────────────────────
model TrainingZone {
  id        Int      @id @default(autoincrement())
  image     String?
  alt       String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── Product Category (Shop Tabs) ─────────────────────
model ProductCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// ─── Product (Shop) ────────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  currency    String   @default("CHF")
  image       String?
  category    String   @default("General")
  features    String[]
  stock       Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
}

// ─── Order ─────────────────────────────────────────────
model Order {
  id          Int            @id @default(autoincrement())
  user        User           @relation(fields: [userId], references: [id])
  userId      Int
  status      ApprovalStatus @default(PENDING)
  totalAmount Float
  notes       String?        // admin notes
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  items       OrderItem[]
}

// ─── CMS: FAQ Items ────────────────────────────────────
model FaqItem {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Order Item ────────────────────────────────────────
model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  unitPrice Float

  @@unique([orderId, productId])
}
